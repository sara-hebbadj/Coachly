<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Coachly.Pages.Auth.LoginPage"
             Title="Login"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#0E0E12}">

    <Grid RowDefinitions="Auto,*">
        <!-- Premium gradient hero -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                Padding="24,58,24,88">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,38,38" />
            </Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush EndPoint="1,1">
                    <GradientStop Color="#6D4CFF" Offset="0.0" />
                    <GradientStop Color="#512BD4" Offset="0.45" />
                    <GradientStop Color="#2E1A8F" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="10">
                <Label Text="Coachly"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#EDE7FF"
                       CharacterSpacing="1.5"
                       Opacity="0.95" />

                <Label Grid.Row="1"
                       Text="Welcome back"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="White"
                       Margin="0,4,0,0" />

                <Label Grid.Row="2"
                       Text="Sign in to manage members, classes, and bookings with ease."
                       FontSize="14"
                       LineHeight="1.3"
                       TextColor="#DDD4FF" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1"
                    Margin="0,-52,0,0">
            <VerticalStackLayout Padding="20,0,20,26"
                                 Spacing="16">

                <!-- Glass-like sign in card -->
                <Border StrokeThickness="1"
                        Padding="22,22,22,18"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1A22}"
                        Stroke="{AppThemeBinding Light=#DFE5FF, Dark=#3A3A4B}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#3C1C7A"
                                Opacity="0.16"
                                Radius="28"
                                Offset="0,12" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="14">
                        <Label Text="Sign in"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

                        <Label Text="Email"
                               FontSize="12"
                               FontAttributes="Bold"
                               CharacterSpacing="0.4"
                               TextColor="{AppThemeBinding Light=#5B6475, Dark=#B3B7C4}" />

                        <Border Padding="14,10"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=#F8F9FF, Dark=#242431}"
                                Stroke="{AppThemeBinding Light=#D8DDF3, Dark=#4A4A61}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Entry Placeholder="you@example.com"
                                   Keyboard="Email"
                                   Text="{Binding Email}"
                                   ClearButtonVisibility="WhileEditing"
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light=#101828, Dark=White}"
                                   PlaceholderColor="{AppThemeBinding Light=#8A93A6, Dark=#8F95A8}" />
                        </Border>

                        <Label Text="Password"
                               FontSize="12"
                               FontAttributes="Bold"
                               CharacterSpacing="0.4"
                               TextColor="{AppThemeBinding Light=#5B6475, Dark=#B3B7C4}" />

                        <Border Padding="14,10"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=#F8F9FF, Dark=#242431}"
                                Stroke="{AppThemeBinding Light=#D8DDF3, Dark=#4A4A61}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Entry Placeholder="Enter your password"
                                   IsPassword="True"
                                   Text="{Binding Password}"
                                   BackgroundColor="Transparent"
                                   TextColor="{AppThemeBinding Light=#101828, Dark=White}"
                                   PlaceholderColor="{AppThemeBinding Light=#8A93A6, Dark=#8F95A8}" />
                        </Border>

                        <Label Text="{Binding ErrorMessage}"
                               FontSize="12"
                               TextColor="#DC2626" />

                        <Button Text="Sign In"
                                Command="{Binding LoginCommand}"
                                HeightRequest="52"
                                CornerRadius="14"
                                FontAttributes="Bold"
                                FontSize="15" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
            Text="Google"
            Command="{Binding GoogleSignInCommand}"
            HeightRequest="46"
            CornerRadius="12"
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#222230}"
            TextColor="{AppThemeBinding Light=#101828, Dark=White}"
            BorderColor="{AppThemeBinding Light=#D8DDF3, Dark=#4A4A61}"
            BorderWidth="1" />
                            <Button Grid.Column="1"
            Text="Apple"
            Command="{Binding AppleSignInCommand}"
            HeightRequest="46"
            CornerRadius="12"
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#222230}"
            TextColor="{AppThemeBinding Light=#101828, Dark=White}"
            BorderColor="{AppThemeBinding Light=#D8DDF3, Dark=#4A4A61}"
            BorderWidth="1" />
                        </Grid>

                        <Label Text="For production: configure OAuth client IDs + backend callback endpoints."
       FontSize="11"
       TextColor="{AppThemeBinding Light=#6B7280, Dark=#B6BDCD}" />


                        <HorizontalStackLayout Spacing="6"
                                               HorizontalOptions="Center">
                            <Label Text="New to Coachly?"
                                   VerticalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#B6BDCD}" />
                            <Button Text="Create Account"
                                    Command="{Binding GoToRegisterCommand}"
                                    Padding="6,0"
                                    HeightRequest="34"
                                    MinimumHeightRequest="34"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Primary}"
                                    FontAttributes="Bold" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Demo credentials card -->
                <Border Padding="14"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1A22}"
                        Stroke="{AppThemeBinding Light=#E4E7F5, Dark=#3B3F51}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Demo Accounts"
                               FontAttributes="Bold"
                               FontSize="12"
                               CharacterSpacing="0.5"
                               TextColor="{AppThemeBinding Light=#576074, Dark=#C0C6D6}" />
                        <Label Text="Coach: coach@coachly.app / password123"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#6A7284, Dark=#AEB4C4}" />
                        <Label Text="Client: client@coachly.app / password123"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#6A7284, Dark=#AEB4C4}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>

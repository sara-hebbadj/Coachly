<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Coachly.Pages.Auth.LoginPage"
             Title="Login">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="Coachly" FontSize="28" FontAttributes="Bold" />
            <Label Text="Sign in to continue" TextColor="Gray" />

            <Entry Placeholder="Email" Keyboard="Email" Text="{Binding Email}" />
            <Entry Placeholder="Password" IsPassword="True" Text="{Binding Password}" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" />

            <Button Text="Login" Command="{Binding LoginCommand}" />
            <Button Text="Create Account" Command="{Binding GoToRegisterCommand}" />

            <Label Text="Demo coach: coach@coachly.app / password123" FontSize="12" TextColor="Gray" />
            <Label Text="Demo client: client@coachly.app / password123" FontSize="12" TextColor="Gray" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Coachly.Pages.Auth.RegisterPage"
             Title="Register">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="Create account" FontSize="28" FontAttributes="Bold" />

            <Entry Placeholder="Full Name" Text="{Binding FullName}" />
            <Entry Placeholder="Email" Keyboard="Email" Text="{Binding Email}" />
            <Entry Placeholder="Password" IsPassword="True" Text="{Binding Password}" />

            <Picker Title="I am a..." ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" />

            <Button Text="Register" Command="{Binding RegisterCommand}" />
            <Button Text="Back to Login" Command="{Binding GoToLoginCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

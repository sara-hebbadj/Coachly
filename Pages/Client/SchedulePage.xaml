<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Coachly.Pages.Client.SchedulePage"
             Title="Schedule"
             BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#0E0E12}">
    <ScrollView>
        <VerticalStackLayout Padding="18,24" Spacing="14">
            <Label Text="Weekly Schedule" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#101828, Dark=White}" />
            <Label Text="Plan and reserve your sessions with a premium, simple workflow." FontSize="13" TextColor="{AppThemeBinding Light=#667085, Dark=#B3B8C9}" />

            <Border Padding="14" Stroke="{AppThemeBinding Light=#E2E7FC, Dark=#3A3F54}" BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A22}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Label Text="Mon • HIIT Burn" FontAttributes="Bold" FontSize="15" TextColor="{AppThemeBinding Light=#101828, Dark=White}" />
                    <Label Grid.Column="1" Text="6:00 PM" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                    <Label Grid.Row="1" Grid.ColumnSpan="2" Text="Coach Ava • Studio A" FontSize="12" TextColor="{AppThemeBinding Light=#667085, Dark=#B3B8C9}" />
                </Grid>
            </Border>

            <Border Padding="14" Stroke="{AppThemeBinding Light=#E2E7FC, Dark=#3A3F54}" BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A22}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Label Text="Wed • Yoga Flow" FontAttributes="Bold" FontSize="15" TextColor="{AppThemeBinding Light=#101828, Dark=White}" />
                    <Label Grid.Column="1" Text="7:30 AM" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                    <Label Grid.Row="1" Grid.ColumnSpan="2" Text="Coach Theo • Studio C" FontSize="12" TextColor="{AppThemeBinding Light=#667085, Dark=#B3B8C9}" />
                </Grid>
            </Border>

            <Button Text="Browse All Sessions" HeightRequest="48" CornerRadius="12" FontAttributes="Bold" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
